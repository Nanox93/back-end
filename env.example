# --- Serveur ---
PORT=3001
# URL du frontend (CRM Dossier), pour CORS et pour les redirections OAuth
FRONTEND_URL=http://localhost:5173

# --- La bonne alternance / API Apprentissage ---
# 1. Créer un compte sur https://api.apprentissage.beta.gouv.fr/fr/compte/profil
# 2. Récupérer le jeton d'accès (bouton "Obtenir un jeton d'accès")
# 3. Vérifier l'URL exacte de recherche dans le Swagger une fois connecté
#    (documentation-technique -> tag Offre-Emploi -> operation jobSearch)
#    et ajuster ALTERNANCE_API_BASE_URL / ALTERNANCE_SEARCH_PATH si besoin
#    dans src/services/alternanceApi.js
ALTERNANCE_API_TOKEN=colle_ton_jeton_ici
ALTERNANCE_API_BASE_URL=https://api.apprentissage.beta.gouv.fr

# --- Gmail OAuth (Google Cloud Console) ---
# 1. Aller sur https://console.cloud.google.com/apis/credentials
# 2. Créer un OAuth Client ID de type "Web application"
# 3. Ajouter cette URI de redirection autorisée :
#    http://localhost:3001/api/auth/google/callback  (adapter en prod)
# 4. Activer l'API Gmail dans "APIs & Services" > "Library"
GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxxxxxx
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/google/callback

# --- Session / sécurité minimale ---
# Chaîne aléatoire longue, à générer toi-même (ex: openssl rand -hex 32)
SESSION_SECRET=change_moi
